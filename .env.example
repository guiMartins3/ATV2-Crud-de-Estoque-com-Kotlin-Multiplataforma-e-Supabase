# ─── Variáveis de ambiente do Estocadão ───────────────────────
# Copie este arquivo para .env e preencha com seus dados do Supabase
# NUNCA commite o arquivo .env no repositório!

# URL do seu projeto Supabase
# Exemplo: https://xyzxyzxyz.supabase.co
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co

# Chave anon/public do Supabase (Settings > API > Project API Keys > anon public)
SUPABASE_KEY=sua_chave_anon_aqui

# Porta do servidor (opcional, padrão: 8080)
PORT=8080
